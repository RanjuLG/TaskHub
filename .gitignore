# ============================================================
# TaskHub - .gitignore
# Covers: .NET / ASP.NET Core + Angular
# ============================================================


# ============================================================
# .NET / ASP.NET Core
# ============================================================

# Build outputs
**/bin/
**/obj/

# Visual Studio
**/.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# VS Code
.vscode/

# Rider
.idea/

# NuGet
*.nupkg
**/packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

# Logs
**/logs/
*.log

# Environment / secrets
appsettings.Development.json
**/secrets.json

# Test results
**/TestResults/
*.trx
*.coverage


# ============================================================
# Angular
# ============================================================

# Dependencies
**/node_modules/

# Build output
**/dist/

# Angular cache
**/.angular/

# Environment files (if they contain secrets)
# src/environments/environment.development.ts

# IDE
.editorconfig


# ============================================================
# General
# ============================================================

# OS
.DS_Store
Thumbs.db
desktop.ini

# Zip files
*.zip
*.tar.gz
